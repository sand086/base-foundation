# ==========================================
# 🌍 AMBIENTE DEL SISTEMA (PRODUCCIÓN)
# ==========================================
# Esto le indica a Python que estamos en el entorno real.
# Leerá las llaves originales de la BD y usará las credenciales reales del PAC.
ENVIRONMENT=QA

# ==========================================
# 🗄️ BASE DE DATOS (PRODUCCIÓN)
# ==========================================
DB_USER=tms_root
DB_PASSWORD=tms_db_2026*
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tms_db

# ⚠️ TIP DE SENIOR: En SQLAlchemy, si tu contraseña tiene caracteres especiales 
# como el asterisco (*), es altamente recomendable URL-codificarlo (el * es %2A)
# para evitar errores de conexión. Quedaría así:
DATABASE_URL=postgresql://tms_root:tms_db_2026%2A@localhost:5432/tms_db

# ==========================================
# 🧾 CREDENCIALES DEL PAC (SOLUCIÓN FACTIBLE - PRODUCCIÓN)
# ==========================================
# Reemplaza estos valores por los que te dio Solución Factible en tu contrato
PAC_WSDL_PROD=https://solucionfactible.com/ws/services/Timbrado?wsdl
PAC_USER_PROD=tu_usuario_real_de_produccion
PAC_PASS_PROD=tu_password_real_de_produccion

# ==========================================
# 📂 RUTAS DE ARCHIVOS (PATHS LINUX)
# ==========================================
APP_BASE_PATH=/home/desarrolloas/base-foundation/backend/app
CERT_DIR=/home/desarrolloas/base-foundation/backend/app/certs
STORAGE_DIR=/home/desarrolloas/base-foundation/backend/app/storage/xml_timbrados
TEMPLATES_DIR=/home/desarrolloas/base-foundation/backend/app/templates
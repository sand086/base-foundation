# ==========================================
# 🌍 AMBIENTE DEL SISTEMA (LOCAL / PRUEBAS)
# ==========================================
# Esto le indica a Python que estamos en Sandbox.
# Usará las llaves "_qa" de la BD y no consumirá timbres reales del PAC.
ENVIRONMENT=QA

# ==========================================
# 🗄️ BASE DE DATOS (LOCAL)
# ==========================================
DB_USER=postgres
DB_PASSWORD=root
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tms_db1

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ==========================================
# 📂 RUTAS DE ARCHIVOS (PATHS LOCALES WINDOWS)
# ==========================================
APP_BASE_PATH=C:\xampp\htdocs\github\base-foundation\backend\app
CERT_DIR=C:\xampp\htdocs\github\base-foundation\backend\app\certs
STORAGE_DIR=C:\xampp\htdocs\github\base-foundation\backend\app\storage\xml_timbrados
TEMPLATES_DIR=C:\xampp\htdocs\github\base-foundation\backend\app\templates